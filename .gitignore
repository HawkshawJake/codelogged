# -----------------------------------------------------------------------
# Secrets & environment — never commit these
# -----------------------------------------------------------------------
.env
.env.*
!.env.example          # keep the example file

# -----------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# -----------------------------------------------------------------------
# Database files — contain real user data
# -----------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
instance/

# -----------------------------------------------------------------------
# Node / frontend
# -----------------------------------------------------------------------
client/node_modules/
client/dist/
client/.env
client/.env.*
!client/.env.example

# -----------------------------------------------------------------------
# OS & editor noise
# -----------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# -----------------------------------------------------------------------
# Logs & debug
# -----------------------------------------------------------------------
*.log
pip-log.txt
