# .env.example
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Flask session signing key — generate a strong random string for production
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# SQLite (default) or a full connection string for Postgres/MySQL in production
DATABASE_URL=sqlite:///codelogged_dev.db

# Anthropic API key — leave empty to use the stub responses during development
ANTHROPIC_API_KEY=

# Model used for task generation and feedback (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6
